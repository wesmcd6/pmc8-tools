# Distributed Caddyfile — serves pre-built PWA from wwwroot (no Kestrel)
# Mount commands route through Node mount-proxy on :5258

http://:5257 {
	handle /mount-proxy/* {
		reverse_proxy localhost:5258
	}

	handle {
		root * wwwroot
		try_files {path} /index.html
		file_server
	}
}

:5256 {
	tls internal {
		on_demand
	}

	header {
		Permissions-Policy "accelerometer=(self), gyroscope=(self)"
	}

	handle /mount-proxy/* {
		reverse_proxy localhost:5258
	}

	handle {
		root * wwwroot
		try_files {path} /index.html
		file_server
	}
}
